# ============================================
# CodeQ-Mate Environment Configuration
# ============================================
# Copy this file and rename to .env.local
# Fill in your API keys below

# ============================================
# REQUIRED: LLM API Keys
# ============================================

# Google Gemini API Key (REQUIRED)
# Used for: Answer generation, query processing
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/minute, generous limits
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# OPTIONAL: Database Configuration
# ============================================

# Supabase Configuration (OPTIONAL - for production)
# Used for: Persistent vector storage, pgvector indexing
# Get your credentials at: https://supabase.com/dashboard
# Note: Current demo mode uses in-memory storage, database not required
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key

# ============================================
# OPTIONAL: GitHub Configuration
# ============================================

# GitHub Personal Access Token (OPTIONAL - for private repos)
# Used for: Cloning private repositories, higher rate limits
# Get your token at: https://github.com/settings/tokens
# Scopes needed: repo (for private repos)
# Note: Not required for public repositories
# GITHUB_TOKEN=your_github_personal_access_token

# ============================================
# OPTIONAL: Hugging Face Configuration
# ============================================

# Hugging Face API Token (OPTIONAL - for faster model downloads)
# Used for: Downloading IndoBERT/sentence-transformers models
# Get your token at: https://huggingface.co/settings/tokens
# Note: Not required, but speeds up first-time model downloads
# HUGGING_FACE_TOKEN=your_hugging_face_token

# ============================================
# OPTIONAL: Application Configuration
# ============================================

# Backend URL (OPTIONAL - for custom deployment)
# Default: http://localhost:8000
# BACKEND_URL=http://localhost:8000

# Frontend URL (OPTIONAL - for custom deployment)
# Default: http://localhost:3000
# FRONTEND_URL=http://localhost:3000

# Environment Mode (OPTIONAL)
# Options: development, production
# Default: development
# NODE_ENV=development

# ============================================
# OPTIONAL: Model Configuration
# ============================================

# IndoBERT Model Name (OPTIONAL - for custom models)
# Default: firqaaa/indo-sentence-bert-base
# Fallback: all-MiniLM-L6-v2
# INDOBERT_MODEL=firqaaa/indo-sentence-bert-base

# BM25 Parameters (OPTIONAL - for tuning)
# Default: k1=1.8, b=0.75
# BM25_K1=1.8
# BM25_B=0.75

# Hybrid Retrieval Alpha (OPTIONAL - for tuning)
# Range: 0.0-1.0 (0.0=100% semantic, 1.0=100% BM25)
# Default: 0.5
# HYBRID_ALPHA=0.5

# Similarity Threshold (OPTIONAL - for tuning)
# Range: 0.0-1.0 (higher = more precise, lower recall)
# Default: 0.15
# SIMILARITY_THRESHOLD=0.15

# ============================================
# OPTIONAL: Logging Configuration
# ============================================

# Log Level (OPTIONAL)
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
# LOG_LEVEL=INFO

# ============================================
# OPTIONAL: Performance Configuration
# ============================================

# Max Chunk Size (OPTIONAL - tokens)
# Default: 512
# MAX_CHUNK_SIZE=512

# Chunk Overlap (OPTIONAL - tokens)
# Default: 50
# CHUNK_OVERLAP=50

# Top K Results (OPTIONAL)
# Default: 20
# TOP_K_RESULTS=20

# ============================================
# NOTES
# ============================================
# 1. REQUIRED keys must be set for the application to work
# 2. OPTIONAL keys have sensible defaults
# 3. Never commit this file to version control
# 4. Keep your API keys secret and secure
# 5. Restart backend/frontend after changing values

# ============================================
# QUICK START GUIDE
# ============================================
# 1. Get Gemini API Key: https://aistudio.google.com/app/apikey
# 2. Copy this template to .env.local
# 3. Replace "your_gemini_api_key_here" with your actual key
# 4. Save the file
# 5. Start backend: cd backend && python -m uvicorn app.main:app --reload
# 6. Start frontend: cd frontend && npm run dev
# 7. Open browser: http://localhost:3000

# ============================================
# TROUBLESHOOTING
# ============================================
# - "GEMINI_API_KEY not found" → Set GEMINI_API_KEY above
# - "Invalid API key" → Check your key at https://aistudio.google.com
# - "Rate limit exceeded" → Wait a minute or upgrade your plan
# - "Model not found" → First run downloads ~500MB, be patient
# - "Permission denied" → Check GitHub token scopes if using private repos
